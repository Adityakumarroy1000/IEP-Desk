{
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/[...path].js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path].js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
