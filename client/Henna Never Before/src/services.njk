---
layout: base.njk
permalink: /services/
---

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Services</p>
    <h1>Henna Never Before - Service Gallery</h1>
    <p class="hero-copy">Every service below uses your real photos and the full details from your text notes.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="service-list">
      {% for service in services_detail %}
      {% set serviceId = "service-" ~ loop.index %}
      <article class="service-block" id="{{ serviceId }}">
        <div class="service-layout">
          <div class="service-info">
            <div class="service-header">
              <div>
                <h2>{{ service.name }}</h2>
                <p class="muted">{{ service.description }}</p>
              </div>
              <div class="service-price">
                <span class="pill">Price Range</span>
                <p>{{ service.price_range }}</p>
              </div>
            </div>

            {% if service.best_for %}
            <p class="service-best"><strong>Best For:</strong> {{ service.best_for }}</p>
            {% endif %}

            {% if service.options %}
            <div class="service-details">
              <p class="label">Package Options</p>
              <ul class="detail-list">
                {% for option in service.options %}
                <li>{{ option }}</li>
                {% endfor %}
              </ul>
            </div>
            {% endif %}

            {% if service.highlights %}
            <div class="service-details">
              <p class="label">Highlights</p>
              <ul class="detail-list">
                {% for item in service.highlights %}
                <li>{{ item }}</li>
                {% endfor %}
              </ul>
            </div>
            {% endif %}
          </div>

          {% if service.images and service.images.length %}
          <div class="service-feature">
            <a class="service-feature-link" href="#{{ serviceId }}-img-1">
              <img src="{{ service.images[0] }}" alt="{{ service.name }} featured image" />
            </a>
          </div>
          {% endif %}
        </div>

        <div class="service-gallery">
          {% for img in service.images %}
          <a class="service-thumb" href="#{{ serviceId }}-img-{{ loop.index }}">
            <img src="{{ img }}" alt="{{ service.name }} photo {{ loop.index }}" />
          </a>
          {% endfor %}
        </div>

        {% if service.images and service.images.length %}
          {% for img in service.images %}
          {% set prevIndex = loop.index - 1 %}
          {% set nextIndex = loop.index + 1 %}
          {% if loop.first %}{% set prevIndex = loop.length %}{% endif %}
          {% if loop.last %}{% set nextIndex = 1 %}{% endif %}
          <div class="lightbox" id="{{ serviceId }}-img-{{ loop.index }}">
            <a class="lightbox-close" href="#{{ serviceId }}" aria-label="Close image">Close</a>
            <a class="lightbox-nav prev" href="#{{ serviceId }}-img-{{ prevIndex }}" aria-label="Previous image">‹</a>
            <a class="lightbox-nav next" href="#{{ serviceId }}-img-{{ nextIndex }}" aria-label="Next image">›</a>
            <div class="lightbox-content">
              <img class="lightbox-hero" src="{{ img }}" alt="{{ service.name }} photo {{ loop.index }}" />
              <div class="lightbox-caption">
                <h3>{{ service.name }}</h3>
                <p class="muted">{{ service.description }}</p>
              </div>
              <div class="lightbox-gallery">
                {% for thumb in service.images %}
                <a href="#{{ serviceId }}-img-{{ loop.index }}">
                  <img src="{{ thumb }}" alt="{{ service.name }} thumbnail {{ loop.index }}" />
                </a>
                {% endfor %}
              </div>
            </div>
          </div>
          {% endfor %}
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta">
  <div class="container cta-inner">
    <div>
      <h2>Ready to reserve your date?</h2>
      <p class="muted">Share your event details and we will confirm availability.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-solid" href="/contact/">Request Booking</a>
      <a class="btn btn-ghost" href="/contact/">Ask a Question</a>
    </div>
  </div>
</section>
