---
layout: base.njk
---

<section class="hero">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow">Premium Henna � Clean Ingredients � Deep Stain</p>
      <h1>Elevate every celebration with henna that looks as rich as it feels.</h1>
      <p class="hero-copy">Artisan blended cones with a smooth glide, fast drying, and a deep maroon stain. Created for brides, artists, and modern minimalists who want a flawless finish.</p>
      <div class="hero-actions">
        <a class="btn btn-solid" href="/products/">Browse Products</a>
        <a class="btn btn-outline" href="/services/">View Services</a>
      </div>
      <div class="trust-row">
        <div>
          <p class="trust-value">48 hrs</p>
          <p class="muted">Peak stain time</p>
        </div>
        <div>
          <p class="trust-value">100% Natural</p>
          <p class="muted">No additives</p>
        </div>
        <div>
          <p class="trust-value">4.9/5</p>
          <p class="muted">Customer rating</p>
        </div>
      </div>
    </div>
    <div class="hero-card">
      <div class="hero-badge">Bundle Offer</div>
      <h3>Bridal Glow Kit</h3>
      <p class="muted">4 Special Regular Cone + Premium Nail Tint + Herbal Hair Pack</p>
      <div class="price">650 BDT<span>730 BDT</span></div>
      <ul class="checklist">
        <li>Rich maroon finish</li>
        <li>Stays vibrant for 10+ days</li>
        <li>Gift-ready packaging</li>
      </ul>
      <a class="btn btn-solid btn-full" href="/products/">Reserve Kit</a>
    </div>
  </div>
</section>



{% for item in products | slice(0, 4) %}
<div class="lightbox" id="lightbox-home-{{ loop.index }}">
  <a class="lightbox-close" href="#home-products" aria-label="Close image">Close</a>
  <div class="lightbox-content">
    <img src="{{ item.image }}" alt="{{ item.name }}" />
    <div class="lightbox-caption">
      <h3>{{ item.name }}</h3>
      <p class="muted">{{ item.desc }}</p>
    </div>
  </div>
</div>
{% endfor %}

