<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Henna Never Before � luxury henna essentials crafted with care." />
    <title>Henna Never Before</title>    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
        <header class="site-header">
      <div class="container header-inner">
        <div class="brand">
          <img src="/assets/images/logo.png" alt="Henna Never Before" class="brand-logo" />
          <div>
            <p class="brand-name">Henna Never Before</p>
            <p class="brand-tagline">Where Pure Henna Becomes Royal Art</p>
          </div>
        </div>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">Menu</button>
        <nav class="nav">
          <a href="/">Home</a>
          <a href="/products/">Products</a>
          <a href="/services/">Services</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </nav>
        <div class="header-cta">
          <a class="btn btn-ghost" href="https://wa.me/8801622339582">WhatsApp Order</a>
          <a class="btn btn-solid" href="/products/">Shop Collection</a>
        </div>
      </div>
      <div class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
        <div class="container">
          <a href="/">Home</a>
          <a href="/products/">Products</a>
          <a href="/services/">Services</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <div class="mobile-cta">
            <a class="btn btn-ghost" href="https://wa.me/8801622339582">WhatsApp Order</a>
            <a class="btn btn-solid" href="/products/">Shop Collection</a>
          </div>
        </div>
      </div>
    </header>

    <main id="main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <p class="brand-name">Henna Never Before</p>
          <p class="muted">Where Pure Henna Becomes Royal Art</p>
        </div>
        <div class="footer-links">
          <a href="/products/">Products</a>
          <a href="/services/">Services</a>
          <a href="/contact/">Support</a>
        </div>
        <p class="muted">� 2026 Henna Never Before. All rights reserved.</p>
      </div>
    </footer>
      <script>
      (function () {
        var toggle = document.querySelector(".nav-toggle");
        var mobileNav = document.getElementById("mobile-nav");
        if (!toggle || !mobileNav) return;

        function closeMenu() {
          toggle.setAttribute("aria-expanded", "false");
          mobileNav.classList.remove("is-open");
        }

        toggle.addEventListener("click", function () {
          var isOpen = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!isOpen));
          mobileNav.classList.toggle("is-open", !isOpen);
        });

        mobileNav.querySelectorAll("a").forEach(function (link) {
          link.addEventListener("click", closeMenu);
        });
      })();
    </script>  </body>
</html>
